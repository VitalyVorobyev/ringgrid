{
  "hot_module_prefixes": [
    "crates/ringgrid/src/detector",
    "crates/ringgrid/src/ring",
    "crates/ringgrid/src/marker",
    "crates/ringgrid/src/pipeline",
    "crates/ringgrid/src/homography",
    "crates/ringgrid/src/pixelmap"
  ],
  "function_line_guard": {
    "line_threshold": 120,
    "allowed_oversized_functions": {}
  },
  "dead_code_allow_guard": {
    "allowed_occurrences": {
      "crates/ringgrid/src/marker/codebook.rs::#[cfg_attr(not(test), allow(dead_code))]": 2,
      "crates/ringgrid/src/marker/codec.rs::#[cfg_attr(not(test), allow(dead_code))]": 5,
      "crates/ringgrid/src/ring/edge_sample.rs::#[allow(dead_code)]": 1,
      "crates/ringgrid/src/ring/radial_profile.rs::#[allow(dead_code)]": 2
    }
  },
  "too_many_arguments_allow_guard": {
    "allowed_occurrences": {}
  },
  "rustdoc_missing_docs_guard": {
    "crate": "ringgrid",
    "max_warnings": 0
  }
}
